# PostgreSQL
DB_NAME=story_db
DB_USER=story_user
DB_PASS=
DB_HOST=localhost
DB_PORT=5432

# Elasticsearch (Docker: docker compose up -d elasticsearch)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_STORIES_INDEX=stories
# ELASTICSEARCH_USERNAME và ELASTICSEARCH_PASSWORD để trống khi dùng Docker Compose dev
# (xpack.security.enabled=false trong docker-compose.yml)

# JWT
JWT_SECRET=

# Groq AI
GROQ_API_KEY=

# Email (Gmail App Password)
EMAIL_USER=
EMAIL_PASS=

# OpenAI (dành cho embedding — tuỳ chọn)
OPENAI_KEY=

# Tài khoản comi.mobi (tuỳ chọn — chỉ cần nếu crawl chương yêu cầu đăng nhập)
COMI_USERNAME=
COMI_PASSWORD=
